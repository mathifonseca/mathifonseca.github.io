---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactCTA from "../components/ContactCTA.astro";
import Hero from "../components/Hero.astro";
---

<BaseLayout
    title="Work | Mathi Fonseca"
    description="Mathi Fonseca's professional experience"
>
    <div class="stack gap-20">
        <main class="wrapper resume">
            <Hero
                title="Work"
                tagline="Principal Solutions Architect<br/>with 15+ years building systems at scale"
            />

            <section class="experience">
                <h2 class="section-title">Experience</h2>

                <div class="job">
                    <div class="job-header">
                        <h3>Payrails</h3>
                        <span class="location">Berlin, Germany</span>
                    </div>
                    <div class="role">
                        <span class="title"
                            >Solutions Architect & Principal Engineer</span
                        >
                        <span class="dates">Dec 2021 – Dec 2025</span>
                    </div>
                    <ul>
                        <li>
                            <strong>Founding engineer</strong> — designed and built
                            the company's technical architecture and product from
                            the ground up
                        </li>
                        <li>
                            Architected the core blueprint powering Payrails'
                            payment and financial services
                        </li>
                        <li>
                            Bridged product, tech, sales, and customer success
                            teams
                        </li>
                        <li>
                            Drove merchant success: onboarding, critical issue
                            resolution, process improvements
                        </li>
                        <li>
                            Supported sales with demos and refined features
                            based on customer input
                        </li>
                    </ul>
                </div>

                <div class="job">
                    <div class="job-header">
                        <h3>Delivery Hero</h3>
                        <span class="location">Berlin, Germany</span>
                    </div>
                    <div class="role">
                        <span class="title"
                            >Global Fintech Principal Engineer</span
                        >
                        <span class="dates">Oct 2020 – Dec 2021</span>
                    </div>
                    <ul>
                        <li>
                            Helped grow the Global Fintech organisation from 3 to 100+ people across 8 specialised teams (Payments, Risk, Compliance, Wallet, Payouts, Integrations, Analytics, Business), powering infrastructure for 50+ countries and $40B in annual GMV
                        </li>
                        <li>
                            Cross-functional consultant helping teams design and
                            scale payments and fraud systems globally
                        </li>
                        <li>
                            Provided architectural guidance ensuring consistency
                            across markets
                        </li>
                        <li>
                            Adapted applications to new countries, payment
                            methods, and use cases
                        </li>
                        <li>
                            Maintained bird's-eye view of fintech projects
                            across teams and regions
                        </li>
                    </ul>
                    <div class="role">
                        <span class="title"
                            >Global Payments Senior Engineering Manager</span
                        >
                        <span class="dates">May 2019 – Oct 2020</span>
                    </div>
                    <ul>
                        <li>
                            Built the Global Fintech team from scratch at
                            Delivery Hero HQ
                        </li>
                        <li>
                            Designed scalable payment solutions across diverse
                            market requirements
                        </li>
                        <li>
                            Expanded payment ecosystem with new methods and
                            unified technical framework
                        </li>
                        <li>
                            Led cross-functional teams for fraud prevention,
                            compliance, and checkout optimization
                        </li>
                    </ul>
                </div>

                <div class="job">
                    <div class="job-header">
                        <h3>PedidosYa</h3>
                        <span class="location">Montevideo, Uruguay</span>
                    </div>
                    <div class="role">
                        <span class="title"
                            >Shopping Tribe Technical Leader</span
                        >
                        <span class="dates">Jan 2019 – Apr 2019</span>
                    </div>
                    <ul>
                        <li>
                            Liaison between all engineers in the Shopping Tribe
                            and cross-team contact
                        </li>
                        <li>
                            Ensured solid yet flexible architecture consistent
                            across platforms and 12 markets
                        </li>
                    </ul>
                    <div class="role">
                        <span class="title"
                            >Payments & Fraud Prevention Engineering Manager</span
                        >
                        <span class="dates">Sep 2016 – Apr 2019</span>
                    </div>
                    <ul>
                        <li>Led the Payments and Fraud Prevention teams across the #1 food delivery platform in Latin America, operating across 15 countries with $2.5B+ in annual GMV</li>
                        <li>
                            Set OKRs, planned projects, negotiated with payment
                            providers
                        </li>
                        <li>
                            Continued as full-stack engineer, API designer, and
                            system maintainer
                        </li>
                    </ul>
                    <div class="role">
                        <span class="title">Senior Full Stack Engineer</span>
                        <span class="dates">Oct 2013 – Apr 2019</span>
                    </div>
                    <ul>
                        <li>
                            One of the first engineers — built Latin America's
                            leading food delivery platform from scratch
                        </li>
                        <li>
                            Designed and maintained systems from backend APIs to
                            frontend apps across 12 countries
                        </li>
                        <li>
                            Specialized in payment systems and fraud prevention
                            for high-risk Latam markets
                        </li>
                    </ul>
                </div>

                <div class="job">
                    <div class="job-header">
                        <h3>Universidad ORT Uruguay</h3>
                        <span class="location">Montevideo, Uruguay</span>
                    </div>
                    <div class="role">
                        <span class="title"
                            >Software Architecture Professor</span
                        >
                        <span class="dates">Aug 2012 – Apr 2019</span>
                    </div>
                    <ul>
                        <li>
                            Taught Software Architecture for Software
                            Engineering and BSc Computer Science
                        </li>
                        <li>
                            Syllabus: Architectural Patterns, Quality
                            Attributes, Tactics with Java EE
                        </li>
                    </ul>
                    <div class="role">
                        <span class="title"
                            >Software Engineering in the Cloud Professor</span
                        >
                        <span class="dates">Jul 2014 – Sep 2015</span>
                    </div>
                    <ul>
                        <li>
                            Advanced course on cloud architecture, web APIs, and
                            deployment strategies
                        </li>
                    </ul>
                </div>

                <div class="job">
                    <div class="job-header">
                        <h3>MercadoLibre</h3>
                        <span class="location">Montevideo, Uruguay</span>
                    </div>
                    <div class="role">
                        <span class="title">Software Engineer</span>
                        <span class="dates">May 2013 – Oct 2013</span>
                    </div>
                    <ul>
                        <li>
                            API development at Latin America's largest
                            e-commerce platform
                        </li>
                        <li>
                            Architectural decisions under demanding performance
                            restrictions
                        </li>
                    </ul>
                </div>

                <div class="job">
                    <div class="job-header">
                        <h3>Softruck</h3>
                        <span class="location">Belo Horizonte, Brazil</span>
                    </div>
                    <div class="role">
                        <span class="title">CTO</span>
                        <span class="dates">Sep 2015 – Dec 2015</span>
                    </div>
                    <ul>
                        <li>
                            Led technology at AI/transportation startup
                            processing vehicle data across Brazil and Uruguay
                        </li>
                    </ul>
                </div>

                <div class="job collapsed">
                    <div class="job-header">
                        <h3>Earlier Roles</h3>
                    </div>
                    <ul>
                        <li>
                            <strong>Tata Consultancy Services</strong> — Business
                            Analyst & Developer (2010–2013)
                        </li>
                        <li>
                            <strong>TECHO</strong> — IT Manager, Volunteer since 2008
                            (nonprofit fighting poverty)
                        </li>
                        <li>
                            <strong>Universidad ORT</strong> — Teaching Assistant
                            for Databases & Data Structures (2010)
                        </li>
                    </ul>
                </div>
            </section>

            <section class="education">
                <h2 class="section-title">Education</h2>
                <div class="edu-item">
                    <h3>Universidad ORT Uruguay</h3>
                    <p>
                        <strong
                            >Big Data and Machine Learning Specialization</strong
                        > — 2018–2020
                    </p>
                    <p>
                        <strong>BSc in Information Technology</strong> — 2008–2012
                    </p>
                </div>
            </section>

            <section class="skills-section">
                <h2 class="section-title">Skills & Languages</h2>
                <div class="skills-grid">
                    <div class="skill-category">
                        <h4>Technical</h4>
                        <p>
                            Java · Kotlin · Go · Groovy · Python · TypeScript · React · AWS · Kubernetes · Terraform · PostgreSQL · Redis · Kafka · BigQuery
                        </p>
                    </div>
                    <div class="skill-category">
                        <h4>Payments Domain</h4>
                        <p>
                            50+ PSP integrations · Payment orchestration · Fraud prevention · PCI-DSS · GDPR · SCA/PSD2 · AML/KYC
                        </p>
                    </div>
                    <div class="skill-category">
                        <h4>Leadership & Methods</h4>
                        <p>
                            Cross-functional leadership · Technical strategy · Domain-Driven Design · Event-driven architecture · RFC-driven decisions
                        </p>
                    </div>
                    <div class="skill-category">
                        <h4>Languages</h4>
                        <p>
                            Spanish (Native) · English (Fluent) · Portuguese (Professional) · German & Italian (Elementary)
                        </p>
                    </div>
                </div>
            </section>

            <section class="awards">
                <h2 class="section-title">Honors</h2>
                <p>
                    <strong>Graduation Speech</strong> — Selected to represent Information
                    Systems graduates at Universidad ORT Uruguay ceremony, Teatro
                    Solís (2013)
                </p>
            </section>
        </main>

        <ContactCTA />
    </div>
</BaseLayout>

<style>
    .resume {
        display: flex;
        flex-direction: column;
        gap: 3rem;
    }

    .section-title {
        font-size: var(--text-2xl);
        color: var(--gray-0);
        margin-bottom: 1.5rem;
        border-bottom: 1px solid var(--gray-800);
        padding-bottom: 0.5rem;
    }

    .job {
        margin-bottom: 2rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid var(--gray-800);
    }

    .job:last-child {
        border-bottom: none;
    }

    .job-header {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .job-header h3 {
        font-size: var(--text-xl);
        color: var(--gray-0);
        margin: 0;
    }

    .location {
        color: var(--gray-400);
        font-size: var(--text-sm);
    }

    .role {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin: 0.75rem 0 0.5rem;
    }

    .title {
        color: var(--accent-regular);
        font-weight: 600;
    }

    .dates {
        color: var(--gray-400);
        font-size: var(--text-sm);
    }

    .job ul {
        margin: 0.5rem 0 0 1.25rem;
        padding: 0;
        color: var(--gray-300);
    }

    .job li {
        margin-bottom: 0.35rem;
    }

    .job.collapsed ul {
        list-style: none;
        margin-left: 0;
    }

    .edu-item h3 {
        font-size: var(--text-lg);
        color: var(--gray-0);
        margin: 0 0 0.5rem;
    }

    .edu-item p {
        margin: 0.25rem 0;
        color: var(--gray-300);
    }

    .skills-grid {
        display: grid;
        gap: 1.5rem;
    }

    .skill-category h4 {
        color: var(--accent-regular);
        font-size: var(--text-md);
        margin: 0 0 0.5rem;
    }

    .skill-category p {
        color: var(--gray-300);
        margin: 0;
    }

    .awards p {
        color: var(--gray-300);
    }

    @media (min-width: 50em) {
        .resume {
            max-width: 800px;
            margin: 0 auto;
        }

        .skills-grid {
            grid-template-columns: repeat(4, 1fr);
        }
    }
</style>
